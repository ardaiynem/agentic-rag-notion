# You can get your Notion API key from https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_key_here
NOTION_DATABASE_ID=your_database_id_here

# You can get your OpenAI API key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_key_here

# The following are the default values for the Chroma API
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# You can change the model to any of the following:
EMBEDDING_MODEL=all-MiniLM-L6-v2 